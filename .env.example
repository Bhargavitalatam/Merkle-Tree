# =====================================================================
# Ethereum Transaction Verifier Configuration Example
# Copy this file to '.env' and adjust the variables as needed.
# =====================================================================

# (Optional) Custom Ethereum JSON-RPC Endpoint URL. 
# If not provided or left blank, the application will automatically 
# benchmark and fallback to the fastest healthy public RPC node in our 
# resilient default pool (including PublicNode, LlamaRPC, and Ankr).
ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
